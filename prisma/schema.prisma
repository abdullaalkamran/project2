generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  phone        String?
  districtId   String?
  photo        String?
  hubId        String?    // assigned hub for hub_manager, qc_leader, qc_checker, delivery roles
  isVerified   Boolean    @default(false)
  status       String     @default("ACTIVE")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Seller profile fields
  businessName   String?
  ownerName      String?
  address        String?
  nid            String?
  tradeLicense   String?

  // Bank & payment details
  bankName       String?
  accountName    String?
  accountNumber  String?
  routingNumber  String?
  mobileBanking  String?
  mobileNumber   String?

  district        District?    @relation(fields: [districtId], references: [id])
  userRoles       UserRole[]
  sellerLots      Lot[]          @relation("SellerLots")
  qcLeaderLots    Lot[]          @relation("QCLeaderLots")
  qcCheckerLots   Lot[]          @relation("QCCheckerLots")
  buyerOrders     Order[]        @relation("BuyerOrders")
  sellerOrders    Order[]        @relation("SellerOrders")
  bids            Bid[]
  wallet          Wallet?
  qcReports       QCReport[]
  notifications   Notification[]
  paymentRequests PaymentRequest[]
  depositRequests DepositRequest[]
  hubAssignments   HubManagerAssignment[]
  arothAssignments ArothAssignment[]
  arothOrders      Order[]               @relation("ArothOrders")
  arothPrices      ArothPriceEntry[]     @relation("ArothPrices")

  @@index([email])
  @@index([districtId])
  @@index([status])
}

model District {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]

  @@index([name])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  role       String
  assignedAt DateTime @default(now())
  assignedBy String?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
}

// ─── Product Flow: Lots ───────────────────────────────────────────────────────
// Status flow: PENDING_DELIVERY → AT_HUB → IN_QC → QC_SUBMITTED → QC_PASSED/QC_FAILED → LIVE → AUCTION_ENDED

model Lot {
  id               String    @id @default(cuid())
  lotCode          String    @unique
  title            String
  category         String
  quantity         Float
  unit             String    @default("kg")
  grade            String    @default("A")
  hubId            String
  description      String    @default("")
  storageType      String    @default("")
  baggageType      String    @default("")
  baggageQty       Int       @default(0)
  basePrice        Float
  askingPricePerKg Float
  minBidRate       Float?
  minOrderQty      Float?
  sellerId         String?
  sellerName       String
  sellerPhone      String?
  saleType         String    @default("AUCTION")   // AUCTION | FIXED_PRICE
  auctionStartsAt  DateTime?
  auctionEndsAt    DateTime?
  status           String    @default("PENDING_DELIVERY")
  createdAt        DateTime  @default(now())
  receivedAt       DateTime?

  fixedAskingPrice Float?    // set when seller converts unsold auction → fixed price
  sellerTransportCost   Float?   // seller's estimated transportation cost
  sellerTransportShare  String   @default("YES")  // "YES" | "NO" | "HALF"
  freeQtyEnabled    Boolean  @default(false)
  freeQtyPer        Float    @default(0)    // e.g., 40 → "per 40 kg"
  freeQtyAmount     Float    @default(0)    // e.g., 2  → "2 kg free"
  freeQtyUnit       String   @default("kg") // "kg" | "piece"
  listOnMarketplace Boolean?  // QC checker decision to list on marketplace

  // QC assignment — IDs are the source of truth; names kept for display only
  qcLeaderId     String?
  qcLeaderName   String?
  qcCheckerId    String?
  qcCheckerName  String?
  qcTaskStatus   String?   // PENDING | IN_PROGRESS | SUBMITTED
  verdict        String?   // PASSED | FAILED | CONDITIONAL
  qcNotes        String?
  qcSubmittedAt  DateTime?
  leaderDecision String?   // Approved | Rejected | Pending

  seller    User?     @relation("SellerLots", fields: [sellerId], references: [id])
  qcLeader  User?     @relation("QCLeaderLots", fields: [qcLeaderId], references: [id])
  qcChecker User?     @relation("QCCheckerLots", fields: [qcCheckerId], references: [id])
  qcReport  QCReport?
  orders    Order[]
  bids      Bid[]

  @@index([sellerId])
  @@index([qcLeaderId])
  @@index([qcCheckerId])
  @@index([status])
  @@index([hubId])
  @@index([saleType])
  @@index([createdAt])
}

model QCReport {
  id          String   @id @default(cuid())
  lotId       String   @unique
  checkerId   String?
  checkerName String?
  grade       String
  verdict        String
  minBidRate     Float?
  transportCost  Float?    // QC checker's determined actual transportation cost
  notes          String?
  submittedAt    DateTime @default(now())

  // Field confirmation by QC checker (native JSON: Record<field, "confirmed"|"wrong"|"unset">)
  fieldConfirmations Json?

  // GPS & manual location recorded during inspection
  inspectionLat     Float?
  inspectionLng     Float?
  inspectionAddress String?

  lot     Lot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  checker User? @relation(fields: [checkerId], references: [id])

  @@index([checkerId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id            String    @id @default(cuid())
  orderCode     String    @unique
  lotId         String
  buyerId       String?
  sellerId      String?
  buyerName     String
  sellerName    String
  product       String
  qty           String
  freeQty       Float    @default(0)   // bonus qty given, not charged
  deliveryPoint String
  winningBid       Float
  productAmount    Float     @default(0)   // winningBid × quantity
  transportCost    Float     @default(0)   // QC-determined transport cost (approved by leader)
  sellerTransportCost Float? // seller's original estimate
  buyerTransportCost  Float? // buyer's proposed estimate
  platformFeeRate  Float     @default(5)   // platform commission %
  platformFee      Float     @default(0)   // productAmount × rate / 100
  sellerPayable    Float     @default(0)   // productAmount − platformFee
  totalAmount      Float                   // productAmount + transportCost (buyer pays)
  status           String    @default("CONFIRMED")
  sellerStatus     String    @default("NONE")   // NONE | PENDING_SELLER | ACCEPTED | DECLINED
  assignedTruck    String?
  loadConfirmed    Boolean   @default(false)
  dispatched       Boolean   @default(false)
  delivered        Boolean   @default(false)
  confirmedAt      DateTime  @default(now())
  arrivedAt        DateTime?
  pickedUpAt       DateTime?
  deliveredAt      DateTime?                // when order is fully delivered

  // Aroth (local market agent) routing
  arothId                  String?
  arothName                String?
  arothHubId               String?
  arothStatus              String?   // PENDING | RECEIVED | SOLD | PAYMENT_SENT | SETTLED
  arothSaleAmount          Float?    // amount aroth sold it for in local market
  arothCommissionRate      Float?    // % at time of assignment
  arothCommission          Float?    // arothSaleAmount × rate / 100
  arothNetAmount           Float?    // arothSaleAmount − arothCommission (sent to platform)
  arothPaymentSentAt       DateTime?
  arothPaymentConfirmedAt  DateTime?
  arothSettledAt           DateTime?

  aroth  User? @relation("ArothOrders", fields: [arothId], references: [id])

  // Delivery Hub & Distributor tracking
  hubReceivedAt         DateTime?           // delivery hub confirms receipt
  distributorId         String?
  distributorName       String?
  distributorPhone      String?
  distributorAssignedAt DateTime?
  pickedUpFromHubAt     DateTime?           // distributor picks up from delivery hub
  handoverScannedAt     DateTime?           // hub manager scans QR to confirm delivery man received
  deliveryWeightKg      Float?              // confirmed weight at delivery handover
  hasDamage             Boolean  @default(false)  // damage recorded at handover
  damageNotes           String?             // description of damage if any

  lot    Lot   @relation(fields: [lotId], references: [id])
  buyer  User? @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller User? @relation("SellerOrders", fields: [sellerId], references: [id])

  @@index([lotId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([confirmedAt])
}

// ─── Bids ─────────────────────────────────────────────────────────────────────

model Bid {
  id              String   @id @default(cuid())
  lotId           String
  bidderId        String?
  bidderName      String
  amount          Float
  deliveryPoint   String   @default("")   // delivery hub selected by buyer before bidding
  transportCost   Float?    // buyer's proposed transportation cost
  createdAt       DateTime @default(now())

  lot    Lot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  bidder User? @relation(fields: [bidderId], references: [id])

  @@index([lotId])
  @@index([bidderId])
  @@index([createdAt])
}

// ─── Fleet ────────────────────────────────────────────────────────────────────

model Truck {
  id                  String    @id @default(cuid())
  truckCode           String    @unique
  reg                 String    @unique
  type                String
  capacityKg          Int
  status              String    @default("Available")
  currentDestination  String?
  liveCoordLat        Float?
  liveCoordLng        Float?
  liveCoordsUpdatedAt DateTime?
  photoUrl            String?
  registrationStatus  String    @default("APPROVED")
  registrationNote    String?
  submittedAt         DateTime  @default(now())
  submittedBy         String?
  submittedByName     String?
  hubId               String?
  hubName             String?

  driver Driver?

  @@index([status])
  @@index([hubId])
}

model Driver {
  id            String  @id @default(cuid())
  driverCode    String  @unique
  name          String
  phone         String
  address       String?
  license       String  @unique
  licenseExpiry String
  licensePhotoUrl String?
  nid           String  @unique
  nidPhotoUrl   String?
  photoUrl      String?
  joinDate      String
  truckId       String? @unique

  emergencyContactName       String?
  emergencyContactRelation   String?
  emergencyContactPhone      String?
  emergencyContactAddress    String?
  emergencyContactPhotoUrl   String?
  emergencyContactNidPhotoUrl String?

  truck Truck? @relation(fields: [truckId], references: [id])
}

model TruckInvite {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String?
  phone     String?
  note      String?
  createdBy String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("BDT")
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String
  amount      Float
  description String
  reference   String?
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
}

// ─── Disputes ─────────────────────────────────────────────────────────────────

model Dispute {
  id          String    @id @default(cuid())
  code        String    @unique
  orderId     String?
  orderCode   String
  buyer       String
  seller      String
  product     String
  reason      String
  description String    @default("")
  status      String    @default("OPEN")    // OPEN | IN_REVIEW | RESOLVED | ESCALATED
  priority    String    @default("MEDIUM")  // LOW | MEDIUM | HIGH
  resolution  String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  createdBy   String?

  @@index([status])
  @@index([createdAt])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model PaymentRequest {
  id              String    @id @default(cuid())
  paymentCode     String    @unique
  sellerId        String?
  sellerName      String
  amount          Float
  method          String    @default("Bank Transfer") // Bank Transfer | bKash | Nagad | Cash
  bankDetails     String?   // free-text bank/mobile details
  note            String?
  status          String    @default("PENDING")  // PENDING | APPROVED | PAID | REJECTED
  rejectedReason  String?
  transactionRef  String?   // bank transaction reference entered by admin on payment
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  processedBy     String?   // admin name

  seller User? @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
}

// ─── Deposit Requests (buyer → admin approval required) ───────────────────────

model DepositRequest {
  id             String    @id @default(cuid())
  depositCode    String    @unique
  userId         String
  userName       String
  amount         Float
  method         String
  accountDetails String?
  status         String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  rejectedReason String?
  processedBy    String?
  requestedAt    DateTime  @default(now())
  processedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
}

// ─── Hubs ─────────────────────────────────────────────────────────────────────

model Hub {
  id          String   @id @default(cuid())
  name        String   @unique
  location    String
  type        String   @default("BOTH") // RECEIVING | DELIVERY | BOTH
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  assignments      HubManagerAssignment[]
  arothAssignments ArothAssignment[]

  @@index([isActive])
}

model HubManagerAssignment {
  id     String @id @default(cuid())
  hubId  String
  userId String
  role   String // "hub_manager" | "delivery_hub_manager"

  hub  Hub  @relation(fields: [hubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hubId, userId, role])
  @@index([userId, role])
}

model ArothAssignment {
  id              String   @id @default(cuid())
  hubId           String
  userId          String
  commissionRate  Float    @default(5)  // % deducted from sale amount
  allowedProducts String[] @default([]) // product names the aroth is permitted to sell
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hub  Hub  @relation(fields: [hubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hubId, userId])
  @@index([hubId])
  @@index([userId])
}

model ArothPriceEntry {
  id          String   @id @default(cuid())
  arothId     String
  productName String
  category    String   @default("")
  pricePerKg  Float                      // price in BDT per kg (or per unit)
  unit        String   @default("kg")
  date        String                     // "YYYY-MM-DD" — one entry per product per day per aroth
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  aroth User @relation("ArothPrices", fields: [arothId], references: [id], onDelete: Cascade)

  @@unique([arothId, productName, date])
  @@index([arothId, date])
  @@index([date])
}

// ─── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // LOT_RECEIVED | QC_ASSIGNED | QC_SUBMITTED | QC_APPROVED | QC_REJECTED | ORDER_PLACED | ORDER_ACCEPTED | ORDER_DECLINED | ORDER_DISPATCHED
  title     String
  message   String
  link      String   @default("/")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
